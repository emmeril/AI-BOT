# ============================================
# Required API Keys
# ============================================
EXCHANGE_API_KEY=your_binance_api_key_here
EXCHANGE_SECRET=your_binance_secret_here
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================
# Trading Configuration (Optional with defaults)
# ============================================
SYMBOLS=BTC/USDT,ETH/USDT,DOGE/USDT
MAX_OPEN_POSITIONS=2
ORDER_SIZE_USDT=20
TIMEFRAME=15m
LOOKBACK_CANDLES=200
INTERVAL_MINUTES=5

# ============================================
# AI Signal Settings
# ============================================
AI_SIGNAL_CACHE_ENABLED=true
AI_SIGNAL_CACHE_TTL_MS=900000
MIN_AI_CONFIDENCE=65
ALLOWED_AI_STRENGTHS=MEDIUM,STRONG,EXTREME
AI_RESPONSE_RETRIES=2
GEMINI_MODEL=gemini-1.5-flash-lite

# ============================================
# Support & Resistance Detection
# ============================================
SR_WINDOW_SIZE=5
SR_LEVEL_TOLERANCE=0.005
PRICE_PROXIMITY_THRESHOLD=0.005

# ============================================
# Risk Management
# ============================================
MIN_RR=1.5
MAX_DAILY_LOSS_PCT=3
MAX_DAILY_LOSS_USDT=0
MAX_CONSECUTIVE_LOSSES=3
ATR_TP_MULTIPLIER=1.8
ATR_SL_MULTIPLIER=1.5
REVERSAL_COOLDOWN_MINUTES=10
SYMBOL_COOLDOWN_ENABLED=false
SYMBOL_COOLDOWN_MINUTES=30
SYMBOL_ERROR_COOLDOWN_MINUTES=5

# ============================================
# Kill Switch
# ============================================
KILL_SWITCH_ENABLED=false
STOP_TRADING=false
KILL_SWITCH_FILE=bot-paused.flag

# ============================================
# Profit Tracking
# ============================================
PROFIT_TRACKER_ENABLED=true
PROFIT_TRACKER_FILE=profit-ledger-spot.json
RISK_STATE_FILE=risk-state-spot.json

# ============================================
# Learning Memory
# ============================================
LEARNING_MEMORY_ENABLED=true
LEARNING_MEMORY_FILE=learning-memory-spot.json
LEARNING_MEMORY_MIN_TRADES=5
LEARNING_MEMORY_BAD_WIN_RATE=40
LEARNING_MEMORY_CONFIDENCE_PENALTY=0.6

# ============================================
# Fonnte Alerts (Optional)
# ============================================
FONNTE_ENABLED=false
FONNTE_TOKEN=
FONNTE_TARGET=
FONNTE_API_URL=https://api.fonnte.com/send
FONNTE_COUNTRY_CODE=62

# ============================================
# Demo Mode (for testing without real funds)
# ============================================
EXCHANGE_DEMO=false
