# ======= BINANCE FUTURES TESTNET =======
EXCHANGE_API_KEY=your_exchange_api_key
EXCHANGE_SECRET=your_exchange_secret
EXCHANGE_DEMO=true

# ======= GEMINI AI =======
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-3.1-flash-lite
AI_FILTER_ENABLED=true
MIN_AI_CONFIDENCE=65
ALLOWED_AI_STRENGTHS=MEDIUM,STRONG,EXTREME
AI_RESPONSE_RETRIES=2
AI_EXPLAIN_LOG_ENABLED=true
AI_EXPLAIN_LOG_FILE=ai-explain-log.jsonl
AI_EXPLAIN_LOG_MAX_LINES=5000

# ======= CIRCUIT BREAKER =======
CIRCUIT_BREAKER_ENABLED=true
CIRCUIT_BREAKER_MAX_ERRORS=5
CIRCUIT_BREAKER_PAUSE_MINUTES=15

# ======= EMERGENCY CONTROL =======
KILL_SWITCH_ENABLED=true
STOP_TRADING=false
KILL_SWITCH_FILE=bot-paused.flag
ORDER_RECOVERY_ENABLED=true

# ======= TRADING CONFIG =======
SYMBOL=DOGE/USDT:USDT
SYMBOLS=DOGE/USDT:USDT,1000SHIB/USDT:USDT,1000PEPE/USDT:USDT,1000FLOKI/USDT:USDT,1000BONK/USDT:USDT
MAX_OPEN_POSITIONS=1
LEVERAGE=10
ORDER_SIZE_USDT=100
INTERVAL_MINUTES=5
HTF_TIMEFRAME=30m
TIMEFRAME=15m
LOOKBACK_CANDLES=200
SCAN_ROTATION_BATCH_SIZE=2

# ======= PROFIT TRACKER =======
PROFIT_TRACKER_ENABLED=true
PROFIT_TRACKER_FILE=profit-ledger.json
PROFIT_SYNC_LIMIT=100

LONG_ONLY=true
MIN_RR=1.5
ATR_TP_MULTIPLIER=1.8
TRAILING_CALLBACK_MIN=0.3
TRAILING_CALLBACK_MAX=1.5
TP1_PERCENT=30
TP2_PERCENT=40
TP1_RR=1.0
TP2_RR=2.0
REQUIRED_CONFIRMATION=2
SIDEWAYS_EMA_GAP=0.04
REVERSAL_COOLDOWN_MINUTES=10
SYMBOL_COOLDOWN_ENABLED=true
SYMBOL_COOLDOWN_MINUTES=30
SYMBOL_ERROR_COOLDOWN_MINUTES=5

# ======= RISK FILTERS =======
MAX_FUNDING_RATE=0.10
RISK_PER_TRADE_PCT=1
MAX_DAILY_LOSS_PCT=3
MAX_DAILY_LOSS_USDT=0
MAX_CONSECUTIVE_LOSSES=3
MAX_POSITION_NOTIONAL_USDT=1000

# ======= MARKET REGIME FILTER =======
REGIME_FILTER_ENABLED=true
ALLOWED_MARKET_REGIMES=TRENDING_UP,TRENDING_DOWN
MAX_ATR_PCT=2.5
MIN_ATR_PCT=0.15
MIN_VOLUME_CHANGE_FOR_TREND=-20

# ======= WALK-FORWARD OPTIMIZER =======
WFO_SYMBOLS=DOGE/USDT:USDT,1000SHIB/USDT:USDT,1000PEPE/USDT:USDT,1000FLOKI/USDT:USDT,1000BONK/USDT:USDT
WFO_TIMEFRAME=15m
WFO_HTF_TIMEFRAME=30m
WFO_LOOKBACK_CANDLES=2400
WFO_TRAIN_CANDLES=900
WFO_TEST_CANDLES=300
WFO_INITIAL_EQUITY=1000
WFO_FEE_RATE=0.0008
WFO_OUTPUT_FILE=walk-forward-report.json
WFO_TUNED_ENV_FILE=.env.tuned
WFO_GRID_MIN_RR=1.2,1.5,1.8,2.0
WFO_GRID_ATR_TP=1.5,1.8,2.2,2.6
WFO_GRID_SIDEWAYS_EMA_GAP=0.03,0.04,0.06,0.08
WFO_GRID_CONFIRMATION=1,2,3
WFO_GRID_MIN_ATR_PCT=0.10,0.15,0.25
WFO_GRID_MAX_ATR_PCT=1.8,2.5,3.5

