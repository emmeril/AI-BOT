# ======= BINANCE FUTURES TESTNET =======
EXCHANGE_API_KEY=your_exchange_api_key
EXCHANGE_SECRET=your_exchange_secret
EXCHANGE_DEMO=true

# ======= GEMINI AI =======
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-3.1-flash-lite
AI_FILTER_ENABLED=true
MIN_AI_CONFIDENCE=65
ALLOWED_AI_STRENGTHS=MEDIUM,STRONG,EXTREME

# ======= TRADING CONFIG =======
SYMBOL=XRP/USDT:USDT
LEVERAGE=10
ORDER_SIZE_USDT=100
INTERVAL_MINUTES=5
HTF_TIMEFRAME=30m
TIMEFRAME=15m
LOOKBACK_CANDLES=200

# ======= PROFIT TRACKER =======
PROFIT_TRACKER_ENABLED=true
PROFIT_TRACKER_FILE=profit-ledger.json
PROFIT_SYNC_LIMIT=100

LONG_ONLY=true
MIN_RR=1.5
ATR_TP_MULTIPLIER=1.8
TRAILING_CALLBACK_MIN=0.3
TRAILING_CALLBACK_MAX=1.5
TP1_PERCENT=30
TP2_PERCENT=40
TP1_RR=1.0
TP2_RR=2.0
REQUIRED_CONFIRMATION=2
SIDEWAYS_EMA_GAP=0.04
REVERSAL_COOLDOWN_MINUTES=10

# ======= RISK FILTERS =======
MAX_FUNDING_RATE=0.10
RISK_PER_TRADE_PCT=1
MAX_DAILY_LOSS_PCT=3
MAX_DAILY_LOSS_USDT=0
MAX_CONSECUTIVE_LOSSES=3
MAX_POSITION_NOTIONAL_USDT=1000

# ======= MARKET REGIME FILTER =======
REGIME_FILTER_ENABLED=true
ALLOWED_MARKET_REGIMES=TRENDING_UP,TRENDING_DOWN
MAX_ATR_PCT=2.5
MIN_ATR_PCT=0.15
MIN_VOLUME_CHANGE_FOR_TREND=-20

