# ============================================================
# Binance Spot Grid Bot environment example
# Copy this file to .env, then fill credentials and sizing.
# ============================================================

# ------------------------------------------------------------
# Exchange credentials
# ------------------------------------------------------------
# Use Binance Spot Testnet credentials when EXCHANGE_MODE=testnet.
EXCHANGE_API_KEY=your_binance_api_key_here
EXCHANGE_SECRET=your_binance_secret_here

# Exchange mode: live, testnet, or demo.
# demo is treated as testnet.
EXCHANGE_MODE=testnet

# Legacy fallback when EXCHANGE_MODE is empty.
EXCHANGE_DEMO=false

# ------------------------------------------------------------
# Core bot settings
# ------------------------------------------------------------
SYMBOLS=BTC/USDT
INTERVAL_MINUTES=1
GRID_MODE=ARITHMETIC
GRID_COUNT=10

# ------------------------------------------------------------
# Grid range
# ------------------------------------------------------------
# Set both manual prices to use a fixed range.
# Keep both 0 to let the bot build an automatic range around current price.
GRID_LOWER_PRICE=0
GRID_UPPER_PRICE=0
GRID_RANGE_PCT=5

# Rebuild auto range when the bot starts.
GRID_RESET_RANGE_ON_START=false

# Detect and optionally reset an old stored range that is too far from price.
GRID_STALE_RANGE_DEVIATION_PCT=50
GRID_STALE_RANGE_AUTO_RESET=false

# ------------------------------------------------------------
# Trailing range
# ------------------------------------------------------------
# Trailing only works for auto range. Manual ranges do not trail.
GRID_TRAILING_RANGE_ENABLED=false
GRID_TRAILING_UP_ENABLED=false
GRID_TRAILING_UP_COOLDOWN_MINUTES=0
GRID_TRAILING_DOWN_ENABLED=false
GRID_TRAILING_DOWN_COOLDOWN_MINUTES=0

# ------------------------------------------------------------
# Position sizing
# ------------------------------------------------------------
# Target order size per grid level.
GRID_ORDER_SIZE_USDT=20

# Legacy fallback when GRID_ORDER_SIZE_USDT is empty.
ORDER_SIZE_USDT=20

# If > 0, this caps total grid allocation and takes priority.
# Effective order size becomes GRID_TOTAL_INVESTMENT_USDT / GRID_COUNT.
GRID_TOTAL_INVESTMENT_USDT=0

# ------------------------------------------------------------
# Order behavior
# ------------------------------------------------------------
GRID_MAX_ACTIVE_BUY_ORDERS=5
GRID_MAX_ACTIVE_SELL_ORDERS=5
GRID_RECREATE_ON_START=false
GRID_CANCEL_OUT_OF_RANGE=true
GRID_CANCEL_OUT_OF_RANGE_THRESHOLD_MINUTES=3
GRID_REFILL_ON_FILLED=true
GRID_POST_ONLY=true
GRID_PRICE_PRECISION_MAX_DEVIATION_PCT=0.05

# ------------------------------------------------------------
# Local state and process lock
# ------------------------------------------------------------
GRID_STATE_FILE=grid-state-spot.json
BOT_LOCK_FILE=grid-state-spot.json.lock
BOT_LOCK_STALE_GRACE_MS=2000

# ------------------------------------------------------------
# Safety controls
# ------------------------------------------------------------
# STOP_TRADING=true prevents new orders from being placed.
STOP_TRADING=false

# When enabled, creating KILL_SWITCH_FILE pauses new trading.
KILL_SWITCH_ENABLED=false
KILL_SWITCH_FILE=bot-paused.flag

# 0 disables these boundaries.
GRID_STOP_LOSS_PRICE=0
GRID_TAKE_PROFIT_PRICE=0

# ------------------------------------------------------------
# Optional Smart Range Advisor via Gemini
# ------------------------------------------------------------
# Suggests grid lower/upper range from recent candles and, optionally,
# Google Search market context. If disabled, local manual/auto range is used.
GEMINI_RANGE_ADVISOR_ENABLED=false
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_RANGE_ADVISOR_MIN_INTERVAL_MINUTES=15
GEMINI_RANGE_ADVISOR_TIMEFRAME=1h
GEMINI_RANGE_ADVISOR_CANDLE_LIMIT=100
GEMINI_RANGE_ADVISOR_USE_WEB_SEARCH=true
GEMINI_RANGE_ADVISOR_MAX_SHIFT_PCT=40
GEMINI_RANGE_ADVISOR_MIN_RANGE_WIDTH_PCT=2
GEMINI_RANGE_ADVISOR_MIN_CONFIDENCE=0.55
GEMINI_RANGE_ADVISOR_TIMEOUT_MS=20000
GEMINI_RANGE_ADVISOR_APPLY_ON=AUTO_RANGE_ONLY
GEMINI_RANGE_ADVISOR_STATE_FILE=gemini-range-advisor-state.json

# ------------------------------------------------------------
# Optional WhatsApp alerts via Fonnte
# ------------------------------------------------------------
FONNTE_ENABLED=false
FONNTE_TOKEN=
FONNTE_TARGET=
FONNTE_API_URL=https://api.fonnte.com/send
FONNTE_COUNTRY_CODE=62
FONNTE_TIMEOUT_MS=10000
