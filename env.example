# ------------------------------
# Exchange Configuration (Binance Futures)
# ------------------------------
EXCHANGE_API_KEY=your_api_key_here
EXCHANGE_SECRET=your_secret_here
EXCHANGE_DEMO=true                     # Gunakan mode demo (true/false)

# ------------------------------
# Trading Pair & Timing
# ------------------------------
SYMBOLS=BTC/USDT:USDT,ETH/USDT:USDT,DOGE/USDT:USDT   # Pasangan trading (futures)
TIMEFRAME=15m                          # Timeframe untuk analisis (m/h/d/w)
LOOKBACK_CANDLES=200                   # Jumlah candle yang diambil
INTERVAL_MINUTES=5                     # Interval siklus trading (menit)

# ------------------------------
# Risk & Position Management
# ------------------------------
MAX_OPEN_POSITIONS=2                   # Maksimal posisi terbuka bersamaan
LEVERAGE=10                            # Leverage (x)
ORDER_SIZE_USDT=10                     # Ukuran order per posisi (USDT)
LONG_ONLY=false                        # Hanya melakukan LONG (true/false)

# ------------------------------
# Support & Resistance Detection
# ------------------------------
SR_WINDOW_SIZE=5                       # Window untuk swing points
SR_LEVEL_TOLERANCE=0.005               # Toleransi cluster level (0.5%)
PRICE_PROXIMITY_THRESHOLD=0.005        # Jarak harga ke level S/R (0.5%)

# ------------------------------
# AI Configuration (Google Gemini)
# ------------------------------
GEMINI_API_KEY=your_gemini_api_key_here   # WAJIB diisi
GEMINI_MODEL=gemini-1.5-flash-lite        # Model yang digunakan
MIN_AI_CONFIDENCE=65                      # Minimal confidence (0-100)
ALLOWED_AI_STRENGTHS=MEDIUM,STRONG,EXTREME # Kekuatan sinyal yang diizinkan
AI_RESPONSE_RETRIES=2                     # Jumlah retry jika AI gagal

# AI Signal Cache
AI_SIGNAL_CACHE_ENABLED=true
AI_SIGNAL_CACHE_TTL_MS=                   # Biarkan kosong (otomatis)

# ------------------------------
# Risk Filters
# ------------------------------
MAX_FUNDING_RATE=0.1                     # Maksimal funding rate absolut (0.1 = 0.1%)
MIN_RR=1.5                               # Minimal risk/reward ratio
RISK_PER_TRADE_PCT=1                     # Risiko per trade (% dari equity)
MAX_DAILY_LOSS_PCT=3                     # Maksimal rugi harian (%)
MAX_DAILY_LOSS_USDT=0                    # Maksimal rugi harian (USDT), 0 = tidak aktif
MAX_CONSECUTIVE_LOSSES=3                 # Maksimal loss beruntun

# ATR Multipliers for TP/SL (fallback jika tidak pakai S/R)
ATR_TP_MULTIPLIER=1.8
ATR_SL_MULTIPLIER=1.5

# Unrealized TP/SL: TP profit dan SL loss berbasis unrealized PnL
UNREALIZED_PROFIT_CLOSE_ENABLED=true
UNREALIZED_PROFIT_CLOSE_MIN_USDT=0.02   # Close jika estimasi net PnL > nilai ini; jangan 0 agar fee/slippage tidak membuat realized loss
UNREALIZED_PROFIT_CLOSE_MIN_PCT=0       # Opsional: minimal estimasi net profit % dari notional, 0 = nonaktif
UNREALIZED_PROFIT_CLOSE_FEE_RATE=0.0005  # Estimasi taker fee per sisi (0.0005 = 0.05%)
UNREALIZED_PROFIT_CLOSE_FEE_SIDES=2      # Buffer fee entry+exit agar net posisi tetap positif
UNREALIZED_PROFIT_CLOSE_FEE_BUFFER_USDT=0 # Buffer ekstra untuk slippage/funding
UNREALIZED_CLOSE_SETTLE_DELAY_MS=2000     # Tunggu fill/riwayat trade settle sebelum sync realized PnL
UNREALIZED_LOSS_CLOSE_ENABLED=true        # Aktifkan SL sistem berbasis unrealized PnL
UNREALIZED_LOSS_CLOSE_PCT=30             # Close jika unrealized PnL rugi >= 30% dari margin posisi
UNREALIZED_PROFIT_MONITOR_INTERVAL_MS=1000 # Interval cek TP/SL unrealized saat menunggu siklus berikutnya (min 250ms)

# ------------------------------
# Cooldown & Reversal
# ------------------------------
REVERSAL_COOLDOWN_MINUTES=10             # Cooldown setelah closing posisi
SYMBOL_COOLDOWN_ENABLED=true             # Aktifkan cooldown per simbol setelah loss
SYMBOL_COOLDOWN_MINUTES=30               # Durasi cooldown per simbol
SYMBOL_ERROR_COOLDOWN_MINUTES=5          # Cooldown jika error scanning

# ------------------------------
# Kill Switch / Emergency Stop
# ------------------------------
KILL_SWITCH_ENABLED=false                # Aktifkan kill switch via file atau flag
STOP_TRADING=false                       # Set true untuk stop trading total
KILL_SWITCH_FILE=bot-paused.flag         # Nama file kill switch

# ------------------------------
# Profit & Risk State Tracking
# ------------------------------
PROFIT_TRACKER_ENABLED=false             # Simpan histori profit ke file
PROFIT_TRACKER_FILE=profit-ledger-sr.json
RISK_STATE_FILE=risk-state-sr.json

# ------------------------------
# Fonnte Alert (WhatsApp)
# ------------------------------
FONNTE_ENABLED=false
FONNTE_TOKEN=your_fonnte_token_here
FONNTE_TARGET=08123456789                # Nomor tujuan (tanpa kode negara)
FONNTE_API_URL=https://api.fonnte.com/send
FONNTE_COUNTRY_CODE=62                   # Kode negara (default Indonesia)
